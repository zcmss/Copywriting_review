# --- 1. 环境与私密信息 (核心) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- 2. Python 运行环境与缓存 ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.tox/

# --- 3. 数据库与本地存储 ---
# 忽略所有 sqlite 数据库文件，防止记忆数据上传
*.db
*.sqlite3
*.db-journal

# --- 4. 日志与临时文件 ---
# 忽略日志文件夹，面试官不需要看你的本地调试日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- 5. 操作系统与编辑器 ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp